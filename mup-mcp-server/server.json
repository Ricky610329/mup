{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Ricky610329/mup",
  "description": "MCP server that turns HTML MUP panels into interactive UI tools for LLMs.",
  "repository": {
    "url": "https://github.com/Ricky610329/mup",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mup-mcp-server",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "arguments": [
        "--mups-dir",
        "./examples"
      ]
    }
  ]
}
