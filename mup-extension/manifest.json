{
  "manifest_version": 3,
  "name": "MUP — Model UI Protocol",
  "version": "0.1.0",
  "description": "Bring interactive UI panels to any LLM chat. Load MUP skills and let the AI control them.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "nativeMessaging"
  ],
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "sandbox": {
    "pages": ["sandbox/mup-host.html"]
  },
  "action": {
    "default_title": "Open MUP Panel"
  }
}
